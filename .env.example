# === Supabase ===
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Optional: jika ingin memakai Quran.Foundation dengan app credential via backend.
# Default app memakai AlQuran.cloud + fallback lokal bila Quran.Foundation belum dikonfigurasi.
VITE_QURAN_API_BASE=https://api.alquran.cloud/v1
VITE_QURAN_FOUNDATION_BASE=https://apis.quran.foundation/content/api/v4

# Prayer / Qibla API. AlAdhan tidak perlu API key.
VITE_ALADHAN_BASE=https://api.aladhan.com/v1
VITE_DEFAULT_PRAYER_METHOD=20

# Optional Firebase Cloud Messaging untuk push notification lintas perangkat.
# Isi hanya jika sudah membuat project Firebase Web App.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=

# Optional: analytics ringan.
VITE_ENABLE_ANALYTICS=false
